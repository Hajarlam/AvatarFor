<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Pro</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #f8fafc;
        }
        
        .navbar {
            background: #ffffff !important;
            border-bottom: 3px solid #d4af37; /* Ligne d'accent OR */
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
            padding: 0.8rem 2rem;
        }
        
        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: #1a202c !important;
        }
        
        .navbar-brand i {
            color: #0284c7; /* Bleu clair */
        }
        
        .navbar-nav .nav-link {
            color: #4a5568 !important;
            font-weight: 600;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }
        
        .navbar-nav .nav-link:hover {
            color: #0284c7 !important; /* Bleu clair hover */
        }

        .navbar-nav .nav-link i {
            color: #718096;
            margin-right: 6px;
        }

        .navbar-nav .nav-link:hover i {
            color: #0284c7;
        }

        .dropdown-menu {
            border: 1px solid #edf2f7;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            border-radius: 12px;
        }
        
        .dropdown-item {
            font-weight: 600;
            color: #4a5568;
        }

        .dropdown-item:hover {
            background-color: #f7fafc;
            color: #0284c7;
        }
    </style>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-brain me-2"></i>LMS Pro
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var username = Context.Session.GetString("Username");
                    }
                    
                    @if (userId != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Dashboard">
                                <i class="fas fa-chart-line me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/AIAvatar/Chat">
                                <i class="fas fa-robot me-1"></i>Formateur IA
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Quiz/Exams">
                                <i class="fas fa-file-signature me-1"></i>Examens
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>@username
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Auth/Logout">Déconnexion</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Auth/Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Connexion
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
