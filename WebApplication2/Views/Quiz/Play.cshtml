@model LMS.Data.Quiz
@{
    ViewData["Title"] = "Quiz en cours - " + Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .quiz-play-bg {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
        padding: 3rem 2rem;
    }

    .play-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .play-header {
        background: white;
        padding: 1.5rem 2rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .play-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #2d3748;
        margin: 0;
    }

    .timer-box {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: #fff5f5;
        color: #e53e3e;
        padding: 0.6rem 1.2rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1.1rem;
        border: 1px solid #fed7d7;
    }

    .timer-warning {
        animation: blink 1s infinite alternate;
        background: #fff5f5 !important;
        color: #e53e3e !important;
        border-color: #fc8181 !important;
    }

    @@keyframes blink {
        from { opacity: 1; }
        to { opacity: 0.4; }
    }

    .progress-wrapper {
        margin-bottom: 2rem;
    }

    .progress-bar-bg {
        height: 10px;
        background: #e2e8f0;
        border-radius: 5px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        width: 0%;
        transition: width 0.3s ease;
    }
 
    .progress-text {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        color: #718096;
        margin-top: 0.5rem;
        font-weight: 600;
    }
 
    .question-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        padding: 2.5rem;
        margin-bottom: 2rem;
        display: none;
    }
 
    .question-card.active {
        display: block;
        animation: fadeIn 0.4s ease;
    }
 
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
 
    .question-number {
        font-size: 1.1rem;
        font-weight: 700;
        color: #0284c7;
        margin-bottom: 0.8rem;
    }
 
    .question-text {
        font-size: 1.4rem;
        font-weight: 700;
        color: #2d3748;
        line-height: 1.5;
        margin-bottom: 2rem;
    }
 
    .options-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
 
    .option-item {
        background: #f7fafc;
        border: 2px solid #edf2f7;
        border-radius: 16px;
        padding: 1.2rem 1.5rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.2s ease;
    }
 
    .option-item:hover {
        border-color: #cbd5e0;
        background: #edf2f7;
    }
 
    .option-item.selected {
        border-color: #0284c7;
        background: #f0f9ff;
    }
 
    .option-radio {
        width: 20px;
        height: 20px;
        accent-color: #0284c7;
        cursor: pointer;
    }
 
    .option-text {
        font-size: 1.1rem;
        color: #4a5568;
        font-weight: 600;
    }
 
    .nav-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
 
    .btn-nav {
        background: white;
        color: #4a5568;
        border: 2px solid #edf2f7;
        padding: 1rem 2rem;
        font-size: 1.05rem;
        font-weight: 700;
        border-radius: 15px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
 
    .btn-nav:hover:not(:disabled) {
        border-color: #cbd5e0;
        background: #f7fafc;
    }
 
    .btn-nav:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
 
    .btn-next {
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        color: white;
        border: none;
        box-shadow: 0 5px 15px rgba(2, 132, 199, 0.2);
    }
 
    .btn-next:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(2, 132, 199, 0.3);
    }
</style>

<div class="quiz-play-bg">
    <div class="play-container">
        <!-- Header -->
        <div class="play-header">
            <h1 class="play-title">@Model.Title</h1>
            <div class="timer-box" id="timerBox">
                <i class="fas fa-clock"></i>
                <span id="countdown">00:00</span>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="progress-wrapper">
            <div class="progress-bar-bg">
                <div class="progress-bar-fill" id="progressBar"></div>
            </div>
            <div class="progress-text">
                <span id="progressText">Question 1 sur @Model.Questions.Count</span>
                <span>@Model.Category</span>
            </div>
        </div>

        <!-- Formular -->
        <form id="quizForm" method="post" action="/Quiz/Submit/@Model.Id">
            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                var question = Model.Questions[i];
                <div class="question-card @(i == 0 ? "active" : "")" id="q-card-@i">
                    <div class="question-number">Question @(i + 1) sur @Model.Questions.Count</div>
                    <div class="question-text">@question.Text</div>
                    
                    <div class="options-list">
                        @foreach (var option in question.Options)
                        {
                            <div class="option-item" onclick="selectOption(this, @i, @option.Id)">
                                <input type="radio" 
                                       name="answers[@question.Id]" 
                                       value="@option.Id" 
                                       id="opt-@option.Id"
                                       class="option-radio"
                                       onclick="event.stopPropagation(); syncSelect(this, @i);">
                                <span class="option-text">@option.Text</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Nav Actions -->
            <div class="nav-actions">
                <button type="button" class="btn-nav" id="btnPrev" onclick="navigateQuestion(-1)" disabled>
                    <i class="fas fa-chevron-left me-2"></i>Précédent
                </button>
                <button type="button" class="btn-nav btn-next" id="btnNext" onclick="navigateQuestion(1)">
                    Suivant<i class="fas fa-chevron-right ms-2"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentQuestionIndex = 0;
        const totalQuestions = @Model.Questions.Count;
        let timeRemainingSeconds = @ViewBag.TimeLimitMinutes * 60;

        // Démarrer le compte à rebours
        const timerInterval = setInterval(() => {
            timeRemainingSeconds--;
            
            // Mettre à jour l'affichage
            const minutes = Math.floor(timeRemainingSeconds / 60);
            const seconds = timeRemainingSeconds % 60;
            const formattedMinutes = minutes.toString().padStart(2, '0');
            const formattedSeconds = seconds.toString().padStart(2, '0');
            document.getElementById('countdown').innerText = `${formattedMinutes}:${formattedSeconds}`;

            // Alerte si moins d'une minute
            if (timeRemainingSeconds <= 60) {
                document.getElementById('timerBox').classList.add('timer-warning');
            }

            // Soumettre automatiquement si temps écoulé
            if (timeRemainingSeconds <= 0) {
                clearInterval(timerInterval);
                document.getElementById('quizForm').submit();
            }
        }, 1000);

        // Mettre à jour la barre de progression
        function updateProgress() {
            const percentage = ((currentQuestionIndex + 1) / totalQuestions) * 100;
            document.getElementById('progressBar').style.width = `${percentage}%`;
            document.getElementById('progressText').innerText = `Question ${currentQuestionIndex + 1} sur ${totalQuestions}`;
        }

        // Sélectionner une option
        function selectOption(element, qIndex, optionId) {
            const card = document.getElementById(`q-card-${qIndex}`);
            card.querySelectorAll('.option-item').forEach(item => item.classList.remove('selected'));
            
            element.classList.add('selected');
            const radio = element.querySelector('input[type="radio"]');
            radio.checked = true;
        }

        function syncSelect(radio, qIndex) {
            const card = document.getElementById(`q-card-${qIndex}`);
            card.querySelectorAll('.option-item').forEach(item => item.classList.remove('selected'));
            radio.closest('.option-item').classList.add('selected');
        }

        // Naviguer entre les questions
        function navigateQuestion(direction) {
            // Cacher la carte courante
            document.getElementById(`q-card-${currentQuestionIndex}`).classList.remove('active');

            currentQuestionIndex += direction;

            // Afficher la nouvelle carte
            document.getElementById(`q-card-${currentQuestionIndex}`).classList.add('active');

            // Gérer les boutons
            document.getElementById('btnPrev').disabled = currentQuestionIndex === 0;

            const nextBtn = document.getElementById('btnNext');
            if (currentQuestionIndex === totalQuestions - 1) {
                nextBtn.innerHTML = 'Soumettre<i class="fas fa-check ms-2"></i>';
                nextBtn.type = 'button';
                nextBtn.setAttribute('onclick', 'submitQuiz()');
            } else {
                nextBtn.innerHTML = 'Suivant<i class="fas fa-chevron-right ms-2"></i>';
                nextBtn.type = 'button';
                nextBtn.setAttribute('onclick', 'navigateQuestion(1)');
            }

            updateProgress();
        }

        function submitQuiz() {
            clearInterval(timerInterval);
            document.getElementById('quizForm').submit();
        }

        // Init
        updateProgress();
    </script>
}
