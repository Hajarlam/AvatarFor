@model LMS.Controllers.QuizResultViewModel
@{
    ViewData["Title"] = "Résultats - " + Model.QuizTitle;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .result-bg {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
        padding: 3rem 2rem;
    }

    .result-container {
        max-width: 850px;
        margin: 0 auto;
    }

    .result-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        padding: 3rem;
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }

    .passed-ribbon {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 8px;
        background: linear-gradient(90deg, #48bb78 0%, #38a169 100%);
    }

    .failed-ribbon {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 8px;
        background: linear-gradient(90deg, #f56565 0%, #e53e3e 100%);
    }

    .result-icon {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .icon-passed {
        background: #e6fffa;
        color: #319795;
        box-shadow: 0 10px 25px rgba(49, 151, 149, 0.2);
    }

    .icon-failed {
        background: #fff5f5;
        color: #e53e3e;
        box-shadow: 0 10px 25px rgba(229, 62, 62, 0.2);
    }

    @@keyframes scaleIn {
        from { transform: scale(0); }
        to { transform: scale(1); }
    }

    .result-status-title {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: #2d3748;
    }

    .result-status-subtitle {
        font-size: 1.1rem;
        color: #718096;
        margin-bottom: 2.5rem;
    }

    .metrics-row {
        display: flex;
        justify-content: center;
        gap: 3rem;
        margin-bottom: 3rem;
        flex-wrap: wrap;
    }

    .metric-item {
        text-align: center;
    }

    .metric-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: #2d3748;
        line-height: 1;
    }

    .metric-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: #a0aec0;
        text-transform: uppercase;
        margin-top: 0.5rem;
    }

    .score-circle-wrapper {
        position: relative;
        width: 140px;
        height: 140px;
        margin: 0 auto 1.5rem;
    }

    .score-circle-svg {
        transform: rotate(-90deg);
        width: 100%;
        height: 100%;
    }

    .score-circle-bg {
        fill: none;
        stroke: #edf2f7;
        stroke-width: 12;
    }

    .score-circle-progress {
        fill: none;
        stroke-width: 12;
        stroke-linecap: round;
        transition: stroke-dasharray 1s ease-in-out;
    }

    .progress-passed {
        stroke: #319795;
    }

    .progress-failed {
        stroke: #e53e3e;
    }

    .score-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.8rem;
        font-weight: 800;
        color: #2d3748;
    }

    .btn-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 1rem 2.5rem;
        font-size: 1.05rem;
        font-weight: 700;
        border-radius: 30px;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-primary-action {
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        color: white;
        border: none;
        box-shadow: 0 10px 20px rgba(2, 132, 199, 0.2);
    }
 
    .btn-primary-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 25px rgba(2, 132, 199, 0.3);
    }

    .btn-secondary-action {
        background: white;
        color: #4a5568;
        border: 2px solid #edf2f7;
    }

    .btn-secondary-action:hover {
        background: #f7fafc;
        border-color: #cbd5e0;
    }

    /* Review Section */
    .review-section {
        background: white;
        border-radius: 24px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        padding: 3rem;
    }

    .review-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 2rem;
        text-align: left;
        border-bottom: 2px solid #edf2f7;
        padding-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .review-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .review-item {
        text-align: left;
        border-bottom: 1px solid #edf2f7;
        padding-bottom: 2rem;
    }

    .review-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .review-q-header {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .q-status-badge {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    .q-correct {
        background: #c6f6d5;
        color: #22543d;
    }

    .q-incorrect {
        background: #fed7d7;
        color: #742a2a;
    }

    .review-q-text {
        font-size: 1.15rem;
        font-weight: 700;
        color: #2d3748;
        line-height: 1.4;
    }

    .review-options {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        padding-left: 2.5rem;
    }

    .review-option {
        padding: 0.8rem 1.2rem;
        border-radius: 12px;
        border: 1px solid #edf2f7;
        font-size: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .option-correct-badge {
        border-color: #c6f6d5;
        background: #f0fff4;
        color: #276749;
    }

    .option-wrong-badge {
        border-color: #fed7d7;
        background: #fff5f5;
        color: #9b2c2c;
    }

    .option-neutral-badge {
        background: #f7fafc;
        color: #4a5568;
    }
</style>

<div class="result-bg">
    <div class="result-container">
        <!-- Main Result Card -->
        <div class="result-card">
            @if (Model.Passed)
            {
                <div class="passed-ribbon"></div>
                <div class="result-icon icon-passed">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h1 class="result-status-title">Félicitations !</h1>
                <p class="result-status-subtitle">Vous avez réussi le quiz avec brio.</p>
            }
            else
            {
                <div class="failed-ribbon"></div>
                <div class="result-icon icon-failed">
                    <i class="fas fa-times-circle"></i>
                </div>
                <h1 class="result-status-title">Pas tout à fait...</h1>
                <p class="result-status-subtitle">Ne vous découragez pas, retentez votre chance !</p>
            }

            <div class="metrics-row">
                <div class="metric-item">
                    <div class="score-circle-wrapper">
                        <svg class="score-circle-svg" viewBox="0 0 120 120">
                            <circle class="score-circle-bg" cx="60" cy="60" r="50"></circle>
                            <circle class="score-circle-progress @(Model.Passed ? "progress-passed" : "progress-failed")" 
                                    cx="60" 
                                    cy="60" 
                                    r="50" 
                                    stroke-dasharray="314.16" 
                                    stroke-dashoffset="@(314.16 - (314.16 * Model.Percentage / 100))"></circle>
                        </svg>
                        <div class="score-text" style="@(Model.IsExam ? "font-size: 1.5rem;" : "")">
                            @if (Model.IsExam)
                            {
                                @Model.Grade<span style="font-size: 0.9rem; color: #a0aec0;">/20</span>
                            }
                            else
                            {
                                @Model.Percentage<span>%</span>
                            }
                        </div>
                    </div>
                    <div class="metric-label">@(Model.IsExam ? "Note finale" : "Votre score")</div>
                </div>

                @if (Model.IsExam)
                {
                    <div class="metric-item d-flex flex-column justify-content-center">
                        <div class="metric-value">@Model.Mention</div>
                        <div class="metric-label">Mention</div>
                    </div>
                }

                <div class="metric-item d-flex flex-column justify-content-center">
                    <div class="metric-value">@Model.Score / @Model.TotalQuestions</div>
                    <div class="metric-label">Réponses correctes</div>
                </div>

                <div class="metric-item d-flex flex-column justify-content-center">
                    <div class="metric-value">@(Model.IsExam ? "10/20" : Model.RequiredPercentage + "%")</div>
                    <div class="metric-label">Requis pour valider</div>
                </div>
            </div>

            <div class="btn-actions">
                @if (Model.IsExam)
                {
                    <a href="/Quiz/Bulletin/@ViewContext.RouteData.Values["id"]" class="btn-action btn-primary-action">
                        <i class="fas fa-print me-2"></i>Télécharger le Bulletin (PDF)
                    </a>
                    <a href="/Quiz/Exams" class="btn-action btn-secondary-action">
                        <i class="fas fa-file-signature me-2"></i>Retour aux Examens
                    </a>
                }
                else
                {
                    <a href="/Quiz/Play/@ViewContext.RouteData.Values["id"]" class="btn-action btn-primary-action">
                        <i class="fas fa-redo me-2"></i>Recommencer le Quiz
                    </a>
                    <a href="/Home/Dashboard" class="btn-action btn-secondary-action">
                        <i class="fas fa-home me-2"></i>Retour au Dashboard
                    </a>
                }
            </div>
        </div>

        <!-- Detailled Review Section -->
        <div class="review-section">
            <h2 class="review-title">
                <i class="fas fa-poll-h" style="color: #667eea;"></i>Correction détaillée
            </h2>

            <div class="review-list">
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var question = Model.Questions[i];
                    <div class="review-item">
                        <div class="review-q-header">
                            @if (question.IsCorrect)
                            {
                                <span class="q-status-badge q-correct">
                                    <i class="fas fa-check"></i>
                                </span>
                            }
                            else
                            {
                                <span class="q-status-badge q-incorrect">
                                    <i class="fas fa-times"></i>
                                </span>
                            }
                            <span class="review-q-text">@(i + 1). @question.QuestionText</span>
                        </div>

                        <div class="review-options">
                            @foreach (var option in question.Options)
                            {
                                bool isUserSelected = option.Id == question.SelectedOptionId;
                                string badgeClass = "option-neutral-badge";
                                string icon = "";

                                if (option.IsCorrect)
                                {
                                    badgeClass = "option-correct-badge";
                                    icon = "<i class='fas fa-check-circle'></i>";
                                }
                                else if (isUserSelected && !option.IsCorrect)
                                {
                                    badgeClass = "option-wrong-badge";
                                    icon = "<i class='fas fa-times-circle'></i>";
                                }

                                <div class="review-option @badgeClass">
                                    <span>
                                        @if (isUserSelected)
                                        {
                                            <strong class="me-1">[Votre réponse]</strong>
                                        }
                                        @option.Text
                                    </span>
                                    <span>@Html.Raw(icon)</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
